import { Button, CheckBox, ComboBox, ScrollView, Slider, VerticalBox, HorizontalBox, LineEdit } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "IcoGen Premium";
    width: 900px;
    height: 750px;
    background: #18181b;

    callback browse_images();
    callback browse_output();
    callback generate_icons();

    in property <string> log_text: "In attesa di operazioni...";
    in property <string> selected_files_text: "Nessun file selezionato.";
    in property <string> output_dir_text: "Nessuna cartella selezionata.";
    in property <bool> is_processing: false;
    
    in-out property <string> profile: "Android";
    in-out property <string> custom_sizes: "32,64,128";
    in-out property <string> output_format: "png";
    in-out property <bool> remove_bg: false;
    in-out property <float> bg_tolerance: 10.0;

    HorizontalBox {
        padding: 0px;
        spacing: 0px;

        // LEFT COLUMN
        Rectangle {
            width: 420px;
            background: #18181b;

            ScrollView {
                VerticalBox {
                    padding: 20px;
                    spacing: 20px;

                    Text {
                        text: "✨ IcoGen";
                        font-size: 32px;
                        color: #6366f1;
                        horizontal-alignment: center;
                    }
                    Text {
                        text: "Generatore di Icone Multi-formato";
                        font-size: 16px;
                        color: #a1a1aa;
                        horizontal-alignment: center;
                    }

                    // CARD 1
                    Rectangle {
                        background: #27272a;
                        border-radius: 12px;
                        drop-shadow-color: #00000080;
                        drop-shadow-blur: 8px;
                        drop-shadow-offset-y: 4px;
                        
                        VerticalBox {
                            padding: 16px;
                            spacing: 12px;
                            
                            Text { text: "📁 File e Destinazione"; font-size: 18px; color: #e4e4e7; font-weight: 700; }
                            
                            HorizontalBox {
                                spacing: 10px;
                                Button { text: "Sfoglia Immagini"; clicked => { browse_images(); } enabled: !is_processing; }
                                Text { text: selected_files_text; color: #71717a; vertical-alignment: center; overflow: elide; }
                            }
                            HorizontalBox {
                                spacing: 10px;
                                Button { text: "Sfoglia Destinazione"; clicked => { browse_output(); } enabled: !is_processing; }
                                Text { text: output_dir_text; color: #71717a; vertical-alignment: center; overflow: elide; }
                            }
                        }
                    }

                    // CARD 2
                    Rectangle {
                        background: #27272a;
                        border-radius: 12px;
                        drop-shadow-color: #00000080;
                        drop-shadow-blur: 8px;
                        drop-shadow-offset-y: 4px;
                        
                        VerticalBox {
                            padding: 16px;
                            spacing: 12px;
                            
                            Text { text: "⚙️ Configurazione Profilo"; font-size: 18px; color: #e4e4e7; font-weight: 700; }
                            
                            ComboBox {
                                model: ["Android", "iOS", "Favicon", "Personalizzato"];
                                current-value <=> profile;
                                enabled: !is_processing;
                            }

                            if profile == "Personalizzato" : HorizontalBox {
                                Text { text: "Dimensioni (csv):"; color: #e4e4e7; vertical-alignment: center; }
                                LineEdit {
                                    text <=> custom_sizes;
                                    enabled: !is_processing;
                                }
                            }

                            HorizontalBox {
                                Text { text: "Formato Output:"; color: #e4e4e7; vertical-alignment: center; }
                                ComboBox {
                                    model: ["png", "jpg", "bmp", "ico"];
                                    current-value <=> output_format;
                                    enabled: !is_processing;
                                }
                            }
                        }
                    }

                    // CARD 3
                    Rectangle {
                        background: #27272a;
                        border-radius: 12px;
                        drop-shadow-color: #00000080;
                        drop-shadow-blur: 8px;
                        drop-shadow-offset-y: 4px;
                        
                        VerticalBox {
                            padding: 16px;
                            spacing: 12px;
                            
                            Text { text: "🛠️ Strumenti Avanzati"; font-size: 18px; color: #e4e4e7; font-weight: 700; }
                            
                            CheckBox {
                                text: "Rimuovi Sfondo Monocromatico";
                                checked <=> remove_bg;
                                enabled: !is_processing;
                            }

                            if remove_bg : HorizontalBox {
                                Text { text: "Tolleranza:"; color: #e4e4e7; vertical-alignment: center; }
                                Slider {
                                    minimum: 0.0;
                                    maximum: 255.0;
                                    value <=> bg_tolerance;
                                    enabled: !is_processing;
                                }
                                Text { 
                                    text: round(bg_tolerance / 2.55) + "%"; 
                                    color: #e4e4e7; 
                                    vertical-alignment: center; 
                                }
                            }
                        }
                    }

                    Rectangle {
                        height: 20px;
                    }

                    // BUTTON
                    Button {
                        text: "🚀 Genera Icone!";
                        primary: true;
                        enabled: !is_processing && selected_files_text != "Nessun file selezionato." && output_dir_text != "Nessuna cartella selezionata.";
                        clicked => { generate_icons(); }
                        height: 50px;
                    }
                }
            }
        }

        // RIGHT COLUMN (Console)
        Rectangle {
            background: #09090b; // Very dark for console
            border-width: 0px;
            
            VerticalBox {
                padding: 20px;
                Text {
                    text: "📝 Console di Sistema";
                    font-size: 20px;
                    color: #a1a1aa;
                    font-weight: 700;
                    horizontal-alignment: center;
                }
                
                ScrollView {
                    Text {
                        text: log_text;
                        color: #d4d4d8;
                        font-family: "monospace";
                        font-size: 14px;
                        wrap: word-wrap;
                        vertical-alignment: top;
                    }
                }
            }
        }
    }
}
